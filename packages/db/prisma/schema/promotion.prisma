model Promotion {
  id            String       @id @default(cuid())
  name          String
  description   String?
  discountType  DiscountType @default(PERCENTAGE)
  discountValue Float
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  courses       Course[]     @relation("CoursePromotions")

  @@map("promotions")
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}
