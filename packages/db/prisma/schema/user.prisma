// User model
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  profileImage String?

  // ✅ ฟิลด์ที่เพิ่มใหม่สำหรับหน้า Profile
  address        String?
  phone          String?
  birthday       DateTime?
  educationLevel String?
  school         String?
  province       String?

  // Relations
  sessions          Session[]
  instructorCourses Course[]     @relation("InstructorCourses")
  enrollments       Enrollment[]
  payments          Payment[]
  reviews           Review[]

  @@index([email])
}

// Session model for refresh tokens
model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
}

// Role enum
enum Role {
  USER
  ADMIN
}