model User {
  id             String         @id @default(cuid())
  email          String         @unique
  password       String?
  name           String?
  role           Role           @default(USER)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  profileImage   String?
  address        String?
  phone          String?
  birthday       DateTime?
  educationLevel String?
  school         String?
  province       String?
  lastActive     DateTime       @default(now())
  enrollments    Enrollment[]
  payments       Payment[]
  sessions       Session[]
  reviews        Review[]
  progress       UserProgress[]

  @@index([email])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
}

enum Role {
  USER
  ADMIN
}
