// User model
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String?
  name         String?
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastActive   DateTime @default(now())
  profileImage String?

  address        String?
  phone          String?
  birthday       DateTime?
  educationLevel String?
  school         String?
  province       String?

  // Relations
  sessions    Session[]
  enrollments Enrollment[]
  payments    Payment[]
  progress    UserProgress[]
  reviews     Review[]

  @@index([email])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
}

enum Role {
  USER
  ADMIN
}
