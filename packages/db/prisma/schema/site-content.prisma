// ─────────────────────────────────────────────
// SiteContent — key/value JSON store for homepage sections
// keys: "students" | "stats" | "universities" | "tutors" | "testimonial" | "faqs"
// ─────────────────────────────────────────────
model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  data      Json
  updatedAt DateTime @updatedAt

  @@map("site_content")
}
