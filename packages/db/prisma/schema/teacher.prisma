model Teacher {
  id               String          @id @default(cuid())
  email            String          @unique
  name             String?
  profileImage     String?
  bio              String?
  title            String?
  nickname         String?
  phone            String?
  expertise        String?
  education        String?
  experience       String?
  socialLink       String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  educationHistory String[]        @default([])
  achievements     String[]        @default([])
  quote            String?
  facebookUrl      String?
  instagramUrl     String?
  tiktokUrl        String?
  linkedinUrl      String?
  courseTeachers   CourseTeacher[]
  courses          Course[]        @relation("TeacherCourses")

  @@index([email])
}
