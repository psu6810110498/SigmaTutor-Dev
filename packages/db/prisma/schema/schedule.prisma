model CourseSchedule {
    id            String         @id @default(cuid())
    sessionNumber Int? // ครั้งที่ 1, 2, 3...
    date          DateTime
    startTime     DateTime
    endTime       DateTime
    topic         String
    location      String? // Room or Zoom Link (unified)
    isOnline      Boolean        @default(false)
    status        ScheduleStatus @default(ON_SCHEDULE)

    courseId String
    course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([courseId])
    @@map("course_schedules")
}

enum ScheduleStatus {
    ON_SCHEDULE
    POSTPONED
    CANCELLED
}
