model CourseSchedule {
  id            String         @id @default(cuid())
  sessionNumber Int?
  date          DateTime?
  startTime     DateTime?
  endTime       DateTime?
  topic         String
  location      String?
  isOnline      Boolean        @default(false)
  status        ScheduleStatus @default(ON_SCHEDULE)
  courseId      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  chapterTitle  String?
  materialUrl   String?
  videoUrl      String?
  gumletVideoId String?
  videoProvider VideoProvider  @default(YOUTUBE)
  zoomLink      String?
  course        Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@map("course_schedules")
}

enum ScheduleStatus {
  ON_SCHEDULE
  POSTPONED
  CANCELLED
}
