model Banner {
  id             String         @id @default(cuid())
  title          String
  subtitle       String?
  imageUrl       String
  imageUrlMobile String?
  ctaLink        String?        @default("#")
  ctaText        String?        @default("Learn More")
  isActive       Boolean        @default(true)
  priority       Int            @default(0)
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  position       BannerPosition @default(EXPLORE_TOP)
  deletedAt      DateTime?

  @@map("banners")
}

enum BannerPosition {
  EXPLORE_TOP
  EXPLORE_MIDDLE
  LANDING_HERO
}
