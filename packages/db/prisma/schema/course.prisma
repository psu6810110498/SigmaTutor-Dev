model Course {
  id                 String           @id @default(cuid())
  title              String
  slug               String           @unique
  description        String?
  price              Float
  originalPrice      Float?
  promotionalPrice   Float?
  status             CourseStatus     @default(DRAFT)
  courseType         CourseType       @default(ONLINE)
  demoVideoUrl       String?
  materialUrl        String?
  thumbnail          String?
  thumbnailSm        String?
  thumbnailLg        String?
  categoryId         String?
  levelId            String?
  duration           String?
  videoCount         Int              @default(0)
  maxSeats           Int?
  enrollStartDate    DateTime?
  enrollEndDate      DateTime?
  location           String?
  mapUrl             String?
  zoomLink           String?
  published          Boolean          @default(false)
  tags               String[]         @default([])
  isBestSeller       Boolean          @default(false)
  isRecommended      Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  courseCode         String?
  meetingId          String?
  priceRange         String?
  shortDescription   String?
  gumletVideoId      String?
  videoProvider      VideoProvider    @default(YOUTUBE)
  teacherId          String?
  instructorId       String?
  accessDurationDays Int?             @default(365)
  enrollments        Enrollment[]
  payments           Payment[]
  chapters           Chapter[]
  schedules          CourseSchedule[]
  teachers           CourseTeacher[]
  category           Category?        @relation(fields: [categoryId], references: [id])
  level              Level?           @relation(fields: [levelId], references: [id])
  teacher            Teacher?         @relation("TeacherCourses", fields: [teacherId], references: [id], onDelete: Cascade)
  reviews            Review[]
  progress           UserProgress[]
  coupons            Coupon[]         @relation("CourseCoupons")
  promotions         Promotion[]      @relation("CoursePromotions")
  selfStudySessions  SelfStudySession[]

  @@index([instructorId])
  @@index([teacherId])
  @@index([status])
  @@index([status, categoryId])
  @@index([status, levelId])
  @@index([status, courseType])
  @@index([status, price])
  @@map("courses")
}

model Enrollment {
  id        String           @id @default(cuid())
  userId    String
  courseId  String
  status    EnrollmentStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  expiresAt DateTime?
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
}

model Payment {
  id        String        @id @default(cuid())
  userId    String
  courseId  String
  amount    Float
  status    PaymentStatus @default(PENDING)
  stripeId  String?
  createdAt DateTime      @default(now())
  couponId  String?
  coupon    Coupon?       @relation("PaymentCoupon", fields: [couponId], references: [id])
  course    Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([courseId])
  @@index([stripeId])
}

model CourseTeacher {
  id        String            @id @default(cuid())
  courseId  String
  teacherId String
  role      CourseTeacherRole @default(LEAD)
  order     Int               @default(0)
  course    Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher   Teacher           @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([courseId, teacherId])
  @@index([courseId])
  @@map("course_teachers")
}

model UserProgress {
  id          String   @id @default(cuid())
  userId      String
  courseId    String
  lessonId    String?
  scheduleId  String?
  isCompleted Boolean  @default(true)
  completedAt DateTime @default(now())
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@unique([userId, scheduleId])
  @@index([userId, courseId])
  @@map("user_progress")
}

enum CourseTeacherRole {
  LEAD
  ASSISTANT
  GUEST
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseType {
  ONLINE
  ONLINE_LIVE
  ONSITE
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}
