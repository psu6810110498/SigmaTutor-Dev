model Chapter {
  id        String   @id @default(cuid())
  title     String
  order     Int      @default(0)
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]

  @@index([courseId])
  @@map("chapters")
}

model Lesson {
  id            String        @id @default(cuid())
  title         String
  type          LessonType    @default(VIDEO)
  content       String?
  youtubeUrl    String?
  duration      Int?
  order         Int           @default(0)
  chapterId     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  gumletVideoId String?
  videoProvider VideoProvider @default(YOUTUBE)
  isFree        Boolean       @default(false)
  materialUrl   String?       // URL ไฟล์ PDF/เอกสารจาก R2
  chapter       Chapter       @relation(fields: [chapterId], references: [id], onDelete: Cascade)


  @@index([chapterId])
  @@map("lessons")
}

enum LessonType {
  VIDEO
  FILE
  QUIZ
}

enum VideoProvider {
  YOUTUBE
  GUMLET
}
