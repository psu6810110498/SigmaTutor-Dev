# Copy this file to .env and fill in your values
# DO NOT use the production database URL here!

# Local Development Database (recommended: use Docker or Neon Dev Branch)
# Pooler URL - used by the app at runtime
DATABASE_URL="postgresql://postgres:password@localhost:5434/sigma_db?schema=public"

# Direct URL (non-pooler) - used by Prisma migrate commands only
# For local Docker this is usually the same as DATABASE_URL
# For Neon: create a DEV BRANCH and use the direct (non-pooler) URL here
DIRECT_URL="postgresql://postgres:password@localhost:5434/sigma_db?schema=public"

# Admin Seed Credentials (local only)
ADMIN_EMAIL="admin@sigma_local.com"
ADMIN_PASSWORD="localDevPassword123!"
